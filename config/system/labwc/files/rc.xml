<?xml version="1.0"?>
<labwc_config>

    <core>
        <gap>4</gap>
    </core>

    <theme>
        <name>Adwaita</name>
        <cornerRadius>4</cornerRadius>
    </theme>

    <focus>
        <focusNew>no</focusNew>
        <followMouse>no</followMouse>
        <raiseOnFocus>no</raiseOnFocus>
    </focus>

    <keyboard>
        <default/>

        <!-- Close window -->
        <keybind key="A-F4">
            <action name="Close"/>
        </keybind>

        <!-- Alt+Tab window switcher -->
        <keybind key="A-Tab">
            <action name="NextWindow"/>
        </keybind>

        <!-- Super+Enter: open terminal -->
        <keybind key="W-Return">
            <action name="Execute">
                <command>konsole</command>
            </action>
        </keybind>

        <!-- Super+D: app launcher -->
        <keybind key="W-d">
            <action name="Execute">
                <command>fuzzel</command>
            </action>
        </keybind>

    </keyboard>

    <mouse>
        <default/>
        <!-- Right-click desktop to open menu -->
        <context name="Root">
            <mousebind button="Right" action="Press">
                <action name="ShowMenu">
                    <menu>root-menu</menu>
                </action>
            </mousebind>
        </context>
    </mouse>

</labwc_config>
